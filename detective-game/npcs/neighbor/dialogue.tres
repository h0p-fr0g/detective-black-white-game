[sub_resource type="Resource" id="Resource_pbc2k"]
script = ExtResource("2_10sol")
character_sprite = ExtResource("3_44w73")
text = Array[String](["Nothing different from the usual. ", "Judith liked to have the radio on all the time when she was home. Which was more often than not."])
metadata/_custom_type_script = "uid://dfnb2v0a8awp"

[sub_resource type="Resource" id="Resource_8rwm4"]
