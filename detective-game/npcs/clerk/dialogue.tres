[sub_resource type="Resource" id="Resource_b7lk3"]
script = ExtResource("1_qqixt")
character_sprite = ExtResource("2_xc6on")
text = Array[String](["Good evening, Detective. "])
metadata/_custom_type_script = "uid://dfnb2v0a8awp"

[sub_resource type="Resource" id="Resource_ovhf6"]
script = ExtResource("1_qqixt")
text = Array[String](["I am looking into the unsolved case of Judith Fleming. ", "According to the statement taken by the police, you saw the attack occur on the night of 26th? "])
metadata/_custom_type_script = "uid://dfnb2v0a8awp"

[sub_resource type="Resource" id="Resource_7h3hg"]
script = ExtResource("1_qqixt")
character_sprite = ExtResource("2_xc6on")
text = Array[String](["Ah, that case. Right, I had given a statement. ", "I thought it had been solved by now?", ""])
metadata/_custom_type_script = "uid://dfnb2v0a8awp"

[sub_resource type="Resource" id="Resource_w2chk"]
script = ExtResource("1_qqixt")
text = Array[String](["No, it still remains unsolved. "])
metadata/_custom_type_script = "uid://dfnb2v0a8awp"

[sub_resource type="Resource" id="Resource_e8igm"]
script = ExtResource("1_qqixt")
character_sprite = ExtResource("2_xc6on")
text = Array[String](["Well. That is unfortunate. "])
metadata/_custom_type_script = "uid://dfnb2v0a8awp"

[sub_resource type="Resource" id="Resource_gwghw"]
script = ExtResource("1_qqixt")
character_sprite = ExtResource("2_xc6on")
text = Array[String](["I was closing the store like usual, and I happened to look across the street.", "One of the apartment’s still had the lights on, and I could hear yelling from all the way here. I thought it was odd. "])
metadata/_custom_type_script = "uid://dfnb2v0a8awp"

[sub_resource type="Resource" id="Resource_81gla"]
script = ExtResource("1_qqixt")
text = Array[String](["Why did you think it was odd? Is it not a common occurance around here?"])
metadata/_custom_type_script = "uid://dfnb2v0a8awp"

[sub_resource type="Resource" id="Resource_trv77"]
script = ExtResource("1_qqixt")
character_sprite = ExtResource("2_xc6on")
text = Array[String](["Oh no, Detective. This town is a quiet place. "])
metadata/_custom_type_script = "uid://dfnb2v0a8awp"

[sub_resource type="Resource" id="Resource_05rky"]
script = ExtResource("1_qqixt")
text = Array[String](["Is that all you saw that night or is there something you wish to add?"])
metadata/_custom_type_script = "uid://dfnb2v0a8awp"

[sub_resource type="Resource" id="Resource_8ndb2"]
script = ExtResource("2_cq4v5")
dialogue_entries = Array[ExtResource("1_qqixt")]([SubResource("Resource_gwghw"), SubResource("Resource_81gla"), SubResource("Resource_trv77"), SubResource("Resource_05rky")])
metadata/_custom_type_script = "uid://ctol7mx6xrebc"

[sub_resource type="Resource" id="Resource_st7oa"]
script = ExtResource("4_b7lk3")
text = "Do you mind recounting what you saw that night when you were closing the store?"
next_dialogue = SubResource("Resource_8ndb2")
metadata/_custom_type_script = "uid://b7o0kup6fcwgo"

[sub_resource type="Resource" id="Resource_id83g"]
script = ExtResource("4_b7lk3")
text = "By any chance did you happen to see any movement from the apartment next door?"
metadata/_custom_type_script = "uid://b7o0kup6fcwgo"

[sub_resource type="Resource" id="Resource_iaexf"]
